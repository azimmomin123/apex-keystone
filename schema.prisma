// This file is automatically generated by Keystone, do not modify it manually.
// Modify your Keystone config when you want to change this.

datasource postgresql {
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  provider          = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                        String     @id @default(cuid())
  name                      String     @default("")
  email                     String     @unique @default("")
  password                  String
  role                      Role?      @relation("User_role", fields: [roleId], references: [id])
  roleId                    String?    @map("role")
  phone                     String     @default("")
  specialty                 String     @default("")
  area                      String     @default("")
  telegramId                String     @default("")
  isActive                  Boolean    @default(true)
  passwordResetToken        String?
  passwordResetIssuedAt     DateTime?
  passwordResetRedeemedAt   DateTime?
  from_Lead_assignedTo      Lead[]     @relation("Lead_assignedTo")
  from_Property_agent       Property[] @relation("Property_agent")
  from_Activity_performedBy Activity[] @relation("Activity_performedBy")

  @@index([roleId])
}

model Role {
  id                 String  @id @default(cuid())
  name               String  @default("")
  canManageLeads     Boolean @default(false)
  canManageAllLeads  Boolean @default(false)
  canSeeOtherPeople  Boolean @default(false)
  canEditOtherPeople Boolean @default(false)
  canManagePeople    Boolean @default(false)
  canManageRoles     Boolean @default(false)
  canAccessDashboard Boolean @default(false)
  assignedTo         User[]  @relation("User_role")
}

model Lead {
  id           String     @id @default(cuid())
  name         String     @default("")
  email        String     @default("")
  phone        String     @default("")
  stage        String?    @default("new")
  source       String?    @default("manual")
  priority     String?    @default("medium")
  budget       String     @default("")
  notes        String     @default("")
  assignedTo   User?      @relation("Lead_assignedTo", fields: [assignedToId], references: [id])
  assignedToId String?    @map("assignedTo")
  property     Property?  @relation("Lead_property", fields: [propertyId], references: [id])
  propertyId   String?    @map("property")
  activities   Activity[] @relation("Activity_lead")
  createdAt    DateTime?  @default(now())
  updatedAt    DateTime?  @updatedAt

  @@index([assignedToId])
  @@index([propertyId])
}

model Property {
  id          String    @id @default(cuid())
  address     String    @default("")
  city        String    @default("")
  state       String    @default("")
  zip         String    @default("")
  type        String?   @default("single_family")
  status      String?   @default("active")
  price       Float?
  bedrooms    Int?
  bathrooms   Float?
  sqft        Int?
  yearBuilt   Int?
  description String    @default("")
  mlsNumber   String    @default("")
  agent       User?     @relation("Property_agent", fields: [agentId], references: [id])
  agentId     String?   @map("agent")
  leads       Lead[]    @relation("Lead_property")
  createdAt   DateTime? @default(now())

  @@index([agentId])
}

model Activity {
  id            String    @id @default(cuid())
  type          String
  summary       String    @default("")
  details       String    @default("")
  lead          Lead?     @relation("Activity_lead", fields: [leadId], references: [id])
  leadId        String?   @map("lead")
  performedBy   User?     @relation("Activity_performedBy", fields: [performedById], references: [id])
  performedById String?   @map("performedBy")
  createdAt     DateTime? @default(now())

  @@index([leadId])
  @@index([performedById])
}
